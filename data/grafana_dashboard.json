{
  "title": "AEOA Production Dashboard",
  "uid": "aeoa-prod",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "title": "API Request Rate",
      "type": "stat",
      "gridPos": {"x":0,"y":0,"w":4,"h":4},
      "targets": [{
        "expr": "rate(aeoa_api_requests_total[5m])",
        "legendFormat": "req/s"
      }]
    },
    {
      "title": "API Error Rate",
      "type": "stat",
      "gridPos": {"x":4,"y":0,"w":4,"h":4},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color":"green","value":0},
              {"color":"yellow","value":0.05},
              {"color":"red","value":0.10}
            ]
          }
        }
      },
      "targets": [{
        "expr": "rate(aeoa_api_requests_total{status=~'5..'}[5m]) / rate(aeoa_api_requests_total[5m])",
        "legendFormat": "error rate"
      }]
    },
    {
      "title": "p95 API Latency",
      "type": "stat",
      "gridPos": {"x":8,"y":0,"w":4,"h":4},
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(aeoa_api_latency_seconds_bucket[5m]))",
        "legendFormat": "p95 latency"
      }]
    },
    {
      "title": "ML Model Accuracy",
      "type": "gauge",
      "gridPos": {"x":12,"y":0,"w":4,"h":4},
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              {"color":"red","value":0},
              {"color":"yellow","value":0.6},
              {"color":"green","value":0.8}
            ]
          }
        }
      },
      "targets": [{"expr":"aeoa_ml_accuracy","legendFormat":"accuracy"}]
    },
    {
      "title": "LLM Calls by Tool",
      "type": "timeseries",
      "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "targets": [{
        "expr": "rate(aeoa_llm_requests_total[5m])",
        "legendFormat": "{{tool}}"
      }]
    },
    {
      "title": "LLM Latency Heatmap",
      "type": "heatmap",
      "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "targets": [{
        "expr": "rate(aeoa_llm_latency_seconds_bucket[5m])",
        "legendFormat": "{{le}}"
      }]
    },
    {
      "title": "Emails Processed",
      "type": "timeseries",
      "gridPos": {"x":0,"y":12,"w":8,"h":6},
      "targets": [{
        "expr": "rate(aeoa_emails_processed_total[5m])",
        "legendFormat": "{{status}}"
      }]
    },
    {
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": {"x":8,"y":12,"w":4,"h":6},
      "targets": [{
        "expr": "rate(aeoa_cache_hits_total[5m]) / (rate(aeoa_cache_hits_total[5m]) + 0.001)",
        "legendFormat": "hit rate"
      }]
    },
    {
      "title": "ML Predictions by Method",
      "type": "piechart",
      "gridPos": {"x":12,"y":12,"w":6,"h":6},
      "targets": [{
        "expr": "aeoa_ml_predictions_total",
        "legendFormat": "{{method}}"
      }]
    },
    {
      "title": "Feedback Corrections",
      "type": "timeseries",
      "gridPos": {"x":0,"y":18,"w":12,"h":6},
      "targets": [{
        "expr": "rate(aeoa_feedback_corrections_total[5m])",
        "legendFormat": "{{field}}"
      }]
    },
    {
      "title": "Rate Limit Breaches",
      "type": "timeseries",
      "gridPos": {"x":12,"y":18,"w":12,"h":6},
      "targets": [{
        "expr": "rate(aeoa_rate_limit_hits_total[5m])",
        "legendFormat": "{{action}}"
      }]
    }
  ]
}